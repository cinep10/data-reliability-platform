CREATE TABLE IF NOT EXISTS v05_observability_measurement_day (
  profile_id VARCHAR(64) NOT NULL,
  target_date DATE NOT NULL,
  scenario_name VARCHAR(128) NOT NULL,
  run_id BIGINT NOT NULL,
  source_gen_run_id BIGINT NOT NULL,
  baseline_mode VARCHAR(64) NOT NULL DEFAULT 'same_run_evidence_baseline',
  delta_source_type VARCHAR(64) NOT NULL DEFAULT 'DIRECT_OBSERVABILITY_MEASUREMENT',
  web_hits BIGINT NOT NULL DEFAULT 0,
  wc_hits BIGINT NOT NULL DEFAULT 0,
  canonical_behavior_events BIGINT NOT NULL DEFAULT 0,
  collection_gap_count BIGINT NOT NULL DEFAULT 0,
  collection_gap_rate DECIMAL(18,10) NOT NULL DEFAULT 0,
  canonical_gap_count BIGINT NOT NULL DEFAULT 0,
  canonical_gap_rate DECIMAL(18,10) NOT NULL DEFAULT 0,
  web_uv_ip BIGINT NOT NULL DEFAULT 0,
  wc_uv_pcid BIGINT NOT NULL DEFAULT 0,
  uv_gap_rate DECIMAL(18,10) NOT NULL DEFAULT 0,
  web_checkout_hits BIGINT NOT NULL DEFAULT 0,
  wc_checkout_hits BIGINT NOT NULL DEFAULT 0,
  checkout_missing_rate DECIMAL(18,10) NOT NULL DEFAULT 0,
  web_product_hits BIGINT NOT NULL DEFAULT 0,
  wc_product_hits BIGINT NOT NULL DEFAULT 0,
  product_missing_rate DECIMAL(18,10) NOT NULL DEFAULT 0,
  web_payment_hits BIGINT NOT NULL DEFAULT 0,
  wc_payment_hits BIGINT NOT NULL DEFAULT 0,
  payment_missing_rate DECIMAL(18,10) NOT NULL DEFAULT 0,
  top_missing_stage VARCHAR(128) NULL,
  suspected_root_cause VARCHAR(255) NULL,
  detail_json JSON NULL,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (profile_id, target_date, scenario_name, run_id, source_gen_run_id),
  KEY idx_v05_obs_measure_date (profile_id, target_date, scenario_name),
  KEY idx_v05_obs_measure_run (run_id, source_gen_run_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE IF NOT EXISTS r_v05_observability_analysis_day (
  profile_id VARCHAR(64) NOT NULL,
  target_date DATE NOT NULL,
  scenario_name VARCHAR(128) NOT NULL,
  run_id BIGINT NOT NULL,
  source_gen_run_id BIGINT NOT NULL,
  collection_completeness_score DECIMAL(18,10) NOT NULL DEFAULT 0,
  canonical_observability_score DECIMAL(18,10) NOT NULL DEFAULT 0,
  uv_observability_score DECIMAL(18,10) NOT NULL DEFAULT 0,
  journey_stage_distortion_score DECIMAL(18,10) NOT NULL DEFAULT 0,
  kpi_false_degradation_score DECIMAL(18,10) NOT NULL DEFAULT 0,
  observability_overall_score DECIMAL(18,10) NOT NULL DEFAULT 0,
  observability_risk_level VARCHAR(32) NOT NULL DEFAULT 'low',
  dominant_observability_signal VARCHAR(128) NOT NULL DEFAULT 'normal_observability',
  recommended_semantic_risk VARCHAR(128) NOT NULL DEFAULT 'None',
  analysis_status VARCHAR(32) NOT NULL DEFAULT 'PASS',
  analysis_reason VARCHAR(512) NULL,
  detail_json JSON NULL,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (profile_id, target_date, scenario_name, run_id, source_gen_run_id),
  KEY idx_r_v05_obs_analysis_date (profile_id, target_date, scenario_name),
  KEY idx_r_v05_obs_analysis_run (run_id, source_gen_run_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
