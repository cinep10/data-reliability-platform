-- CASE-OBS-001 / Phase 1 MVP
-- WC collection missing reconciliation view.
-- Purpose: prove that WebServer reality is normal while WC collection evidence is degraded.

CREATE OR REPLACE VIEW v05_wc_collection_reconciliation_day AS
SELECT
    web.profile_id,
    web.dt AS target_date,
    web.source_gen_run_id,
    MAX(web.scenario_id) AS scenario_id,
    MAX(web.scenario_name) AS scenario_name,
    MAX(web.source_generation_scenario) AS source_generation_scenario,

    web.web_hits,
    COALESCE(wc.wc_hits, 0) AS wc_hits,
    GREATEST(web.web_hits - COALESCE(wc.wc_hits, 0), 0) AS collection_gap_count,
    CASE
      WHEN web.web_hits > 0 THEN ROUND(1 - (COALESCE(wc.wc_hits, 0) / web.web_hits), 6)
      ELSE NULL
    END AS collection_gap_rate,

    web.web_uv_ip,
    COALESCE(wc.wc_uv_pcid, 0) AS wc_uv_pcid,
    CASE
      WHEN web.web_uv_ip > 0 THEN ROUND(1 - (COALESCE(wc.wc_uv_pcid, 0) / web.web_uv_ip), 6)
      ELSE NULL
    END AS uv_gap_rate,

    web.web_checkout_hits,
    COALESCE(wc.wc_checkout_hits, 0) AS wc_checkout_hits,
    CASE
      WHEN web.web_checkout_hits > 0 THEN ROUND(1 - (COALESCE(wc.wc_checkout_hits, 0) / web.web_checkout_hits), 6)
      ELSE NULL
    END AS checkout_missing_rate,

    web.web_product_hits,
    COALESCE(wc.wc_product_hits, 0) AS wc_product_hits,
    CASE
      WHEN web.web_product_hits > 0 THEN ROUND(1 - (COALESCE(wc.wc_product_hits, 0) / web.web_product_hits), 6)
      ELSE NULL
    END AS product_missing_rate,

    CASE
      WHEN web.web_hits > 0 AND 1 - (COALESCE(wc.wc_hits, 0) / web.web_hits) >= 0.25 THEN 'high'
      WHEN web.web_hits > 0 AND 1 - (COALESCE(wc.wc_hits, 0) / web.web_hits) >= 0.10 THEN 'warning'
      WHEN web.web_hits > 0 AND 1 - (COALESCE(wc.wc_hits, 0) / web.web_hits) > 0 THEN 'review'
      ELSE 'low'
    END AS observability_risk_level,

    CASE
      WHEN web.web_hits > 0 AND 1 - (COALESCE(wc.wc_hits, 0) / web.web_hits) >= 0.10
        THEN 'WC collection completeness degradation; compare WebServer vs WC evidence before KPI decision'
      ELSE 'No material WC collection gap'
    END AS suspected_root_cause
FROM (
    SELECT
        profile_id,
        dt,
        source_gen_run_id,
        MAX(scenario_id) AS scenario_id,
        MAX(scenario_name) AS scenario_name,
        MAX(source_generation_scenario) AS source_generation_scenario,
        COUNT(*) AS web_hits,
        COUNT(DISTINCT ip) AS web_uv_ip,
        SUM(CASE WHEN LOWER(COALESCE(path, '')) LIKE '%checkout%' OR LOWER(COALESCE(path, '')) LIKE '%payment%' OR LOWER(COALESCE(path, '')) LIKE '%order%' THEN 1 ELSE 0 END) AS web_checkout_hits,
        SUM(CASE WHEN LOWER(COALESCE(path, '')) LIKE '%product%' THEN 1 ELSE 0 END) AS web_product_hits
    FROM stg_webserver_log_hit
    WHERE COALESCE(path, '') NOT REGEXP '\\.(css|js|png|jpg|jpeg|gif|ico|map|woff|woff2|ttf|eot|svg|webp|zip|txt|xml|json)$'
      AND (LOWER(COALESCE(evt, '')) = 'view' OR COALESCE(page_type, '') <> '')
    GROUP BY profile_id, dt, source_gen_run_id
) web
LEFT JOIN (
    SELECT
        profile_id,
        dt,
        source_gen_run_id,
        COUNT(*) AS wc_hits,
        COUNT(DISTINCT COALESCE(pcid, uid, ip)) AS wc_uv_pcid,
        SUM(CASE WHEN LOWER(COALESCE(path, '')) LIKE '%checkout%' OR LOWER(COALESCE(path, '')) LIKE '%payment%' OR LOWER(COALESCE(path, '')) LIKE '%order%' THEN 1 ELSE 0 END) AS wc_checkout_hits,
        SUM(CASE WHEN LOWER(COALESCE(path, '')) LIKE '%product%' THEN 1 ELSE 0 END) AS wc_product_hits
    FROM stg_wc_log_hit
    WHERE COALESCE(path, '') NOT REGEXP '\\.(css|js|png|jpg|jpeg|gif|ico|map|woff|woff2|ttf|eot|svg|webp|zip|txt|xml|json)$'
      AND (LOWER(COALESCE(evt, '')) = 'view' OR COALESCE(page_type, '') <> '')
    GROUP BY profile_id, dt, source_gen_run_id
) wc
  ON web.profile_id = wc.profile_id
 AND web.dt = wc.dt
 AND web.source_gen_run_id = wc.source_gen_run_id;
