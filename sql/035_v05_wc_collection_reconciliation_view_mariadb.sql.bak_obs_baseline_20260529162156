-- CASE-OBS-001 / Operational Observability reconciliation view
-- This view is intentionally schema-tolerant: measurement columns stay in
-- v05_observability_measurement_day, while risk/semantic interpretation comes
-- from r_v05_observability_analysis_day after R analytics runs.
CREATE OR REPLACE VIEW v05_wc_collection_reconciliation_day AS
SELECT
  m.profile_id,
  m.target_date,
  m.scenario_name,
  m.source_gen_run_id,
  m.run_id,
  m.web_hits,
  m.wc_hits,
  m.canonical_behavior_events,
  m.collection_gap_count,
  m.collection_gap_rate,
  m.canonical_gap_count AS web_to_canonical_gap_count,
  m.canonical_gap_rate AS web_to_canonical_gap_rate,
  m.canonical_gap_count,
  m.canonical_gap_rate,
  m.web_uv_ip,
  m.wc_uv_pcid,
  m.uv_gap_rate,
  m.web_checkout_hits,
  m.wc_checkout_hits,
  m.checkout_missing_rate,
  m.web_product_hits,
  m.wc_product_hits,
  m.product_missing_rate,
  m.web_payment_hits,
  m.wc_payment_hits,
  m.payment_missing_rate,
  r.observability_overall_score AS observability_signal_score,
  r.observability_risk_level,
  r.recommended_semantic_risk,
  r.dominant_observability_signal,
  m.top_missing_stage,
  m.suspected_root_cause,
  m.baseline_mode,
  m.delta_source_type,
  m.created_at,
  m.updated_at
FROM v05_observability_measurement_day m
LEFT JOIN r_v05_observability_analysis_day r
  ON r.profile_id = m.profile_id
 AND r.target_date = m.target_date
 AND r.scenario_name = m.scenario_name
 AND r.run_id = m.run_id
 AND r.source_gen_run_id = m.source_gen_run_id;
