CREATE OR REPLACE VIEW v05_wc_collection_reconciliation_day AS
SELECT
  o.profile_id,
  o.target_date,
  o.scenario_name,
  o.source_gen_run_id,
  o.run_id,
  o.web_hits,
  o.wc_hits,
  o.collection_gap_count,
  o.collection_gap_rate,
  o.web_uv_ip,
  o.wc_uv_pcid,
  o.uv_gap_rate,
  o.checkout_web_hits AS web_checkout_hits,
  o.checkout_wc_hits AS wc_checkout_hits,
  o.checkout_missing_rate,
  o.product_web_hits AS web_product_hits,
  o.product_wc_hits AS wc_product_hits,
  o.product_missing_rate,
  o.observability_risk_level,
  o.dominant_observability_signal,
  o.recommended_semantic_risk,
  o.recommended_action_family AS suspected_root_cause
FROM v05_observability_signal_day o;
