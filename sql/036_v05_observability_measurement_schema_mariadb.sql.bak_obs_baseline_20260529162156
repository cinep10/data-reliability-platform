-- v0.5 Operational Observability Measurement schema
-- Safe for repeated install: existing tables are preserved and missing columns are added.

CREATE TABLE IF NOT EXISTS v05_observability_measurement_day (
  profile_id VARCHAR(64) NOT NULL,
  target_date DATE NOT NULL,
  scenario_name VARCHAR(128) NOT NULL,
  run_id BIGINT NOT NULL,
  source_gen_run_id BIGINT NOT NULL,
  baseline_mode VARCHAR(64) NOT NULL DEFAULT 'same_run_evidence_baseline',
  delta_source_type VARCHAR(64) NOT NULL DEFAULT 'DIRECT_OBSERVABILITY_MEASUREMENT',
  web_hits BIGINT NOT NULL DEFAULT 0,
  wc_hits BIGINT NOT NULL DEFAULT 0,
  canonical_behavior_events BIGINT NOT NULL DEFAULT 0,
  collection_gap_count BIGINT NOT NULL DEFAULT 0,
  collection_gap_rate DECIMAL(18,10) NOT NULL DEFAULT 0.0000000000,
  canonical_gap_count BIGINT NOT NULL DEFAULT 0,
  canonical_gap_rate DECIMAL(18,10) NOT NULL DEFAULT 0.0000000000,
  web_uv_ip BIGINT NOT NULL DEFAULT 0,
  wc_uv_pcid BIGINT NOT NULL DEFAULT 0,
  uv_gap_rate DECIMAL(18,10) NOT NULL DEFAULT 0.0000000000,
  web_checkout_hits BIGINT NOT NULL DEFAULT 0,
  wc_checkout_hits BIGINT NOT NULL DEFAULT 0,
  checkout_missing_rate DECIMAL(18,10) NOT NULL DEFAULT 0.0000000000,
  web_product_hits BIGINT NOT NULL DEFAULT 0,
  wc_product_hits BIGINT NOT NULL DEFAULT 0,
  product_missing_rate DECIMAL(18,10) NOT NULL DEFAULT 0.0000000000,
  web_payment_hits BIGINT NOT NULL DEFAULT 0,
  wc_payment_hits BIGINT NOT NULL DEFAULT 0,
  payment_missing_rate DECIMAL(18,10) NOT NULL DEFAULT 0.0000000000,
  top_missing_stage VARCHAR(128) DEFAULT NULL,
  suspected_root_cause VARCHAR(255) DEFAULT NULL,
  detail_json LONGTEXT DEFAULT NULL,
  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY(profile_id,target_date,scenario_name,run_id,source_gen_run_id),
  KEY idx_obs_measure_day(profile_id,target_date,scenario_name),
  KEY idx_obs_measure_run(profile_id,target_date,run_id,source_gen_run_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- Add canonical column names when upgrading from an earlier OBS-001 package.
SET @db := DATABASE();
SET @tbl := 'v05_observability_measurement_day';
SET @sql := IF((SELECT COUNT(*) FROM information_schema.columns WHERE table_schema=@db AND table_name=@tbl AND column_name='canonical_gap_count')=0,
  'ALTER TABLE v05_observability_measurement_day ADD COLUMN canonical_gap_count BIGINT NOT NULL DEFAULT 0 AFTER collection_gap_rate',
  'SELECT 1');
PREPARE s FROM @sql; EXECUTE s; DEALLOCATE PREPARE s;
SET @sql := IF((SELECT COUNT(*) FROM information_schema.columns WHERE table_schema=@db AND table_name=@tbl AND column_name='canonical_gap_rate')=0,
  'ALTER TABLE v05_observability_measurement_day ADD COLUMN canonical_gap_rate DECIMAL(18,10) NOT NULL DEFAULT 0.0000000000 AFTER canonical_gap_count',
  'SELECT 1');
PREPARE s FROM @sql; EXECUTE s; DEALLOCATE PREPARE s;
