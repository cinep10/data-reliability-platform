SET @sql := IF((SELECT COUNT(*) FROM information_schema.columns WHERE table_schema=@db AND table_name=@tbl AND column_name='wc_payment_hits')=0,
  'ALTER TABLE v05_observability_measurement_day ADD COLUMN wc_payment_hits BIGINT NOT NULL DEFAULT 0 AFTER web_payment_hits',
