PREPARE s FROM @sql; EXECUTE s; DEALLOCATE PREPARE s;
SET @sql := IF((SELECT COUNT(*) FROM information_schema.columns WHERE table_schema=@db AND table_name=@tbl AND column_name='payment_missing_rate')=0,
  'ALTER TABLE v05_observability_measurement_day ADD COLUMN payment_missing_rate DECIMAL(18,10) NOT NULL DEFAULT 0.0000000000 AFTER wc_payment_hits',
