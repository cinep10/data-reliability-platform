SET @sql := IF((SELECT COUNT(*) FROM information_schema.columns WHERE table_schema=@db AND table_name=@tbl AND column_name='top_missing_stage')=0,
  'ALTER TABLE v05_observability_measurement_day ADD COLUMN top_missing_stage VARCHAR(128) DEFAULT NULL AFTER payment_missing_rate',
