CREATE TABLE IF NOT EXISTS v05_baseline_distribution_snapshot_day (
  baseline_distribution_id BIGINT NOT NULL AUTO_INCREMENT,
  profile_id VARCHAR(96) NOT NULL,
  target_date DATE NOT NULL,
  baseline_window VARCHAR(24) NOT NULL DEFAULT '30d',
  baseline_type VARCHAR(48) NOT NULL DEFAULT 'calendar_baseline',
  source_scenario VARCHAR(96) NOT NULL DEFAULT 'baseline',
  dimension_name VARCHAR(96) NOT NULL,
  dimension_value VARCHAR(191) NOT NULL,
  baseline_count_avg DOUBLE DEFAULT NULL,
  baseline_count_std DOUBLE DEFAULT NULL,
  baseline_ratio_avg DOUBLE DEFAULT NULL,
  baseline_ratio_std DOUBLE DEFAULT NULL,
  baseline_ratio_p50 DOUBLE DEFAULT NULL,
  baseline_ratio_p95 DOUBLE DEFAULT NULL,
  sample_days INT DEFAULT 0,
  source_table VARCHAR(128) DEFAULT NULL,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (baseline_distribution_id),
  UNIQUE KEY uq_v05_base_dist (profile_id,target_date,baseline_window,baseline_type,source_scenario,dimension_name,dimension_value),
  KEY idx_v05_base_dist_lookup (profile_id,target_date,baseline_window,dimension_name)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE IF NOT EXISTS v05_batch_behavior_distribution_compare_day (
  profile_id VARCHAR(96) NOT NULL,
  dt DATE NOT NULL,
  run_id BIGINT NOT NULL,
  source_gen_run_id BIGINT DEFAULT NULL,
  scenario_name VARCHAR(128) NOT NULL,
  baseline_mode VARCHAR(48) NOT NULL DEFAULT 'temporal_baseline',
  baseline_window VARCHAR(24) NOT NULL DEFAULT '30d',
  dimension_name VARCHAR(96) NOT NULL,
  dimension_value VARCHAR(191) NOT NULL,
  current_count DOUBLE DEFAULT 0,
  current_ratio DOUBLE DEFAULT 0,
  baseline_count_avg DOUBLE DEFAULT NULL,
  baseline_ratio_avg DOUBLE DEFAULT NULL,
  ratio_delta DOUBLE DEFAULT NULL,
  z_score DOUBLE DEFAULT NULL,
  distribution_shift_score DOUBLE DEFAULT NULL,
  baseline_status VARCHAR(64) DEFAULT 'unknown',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (profile_id,dt,run_id,scenario_name,dimension_name,dimension_value),
  KEY idx_v05_dist_compare_lookup (profile_id,dt,scenario_name,run_id)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE IF NOT EXISTS r_batch_behavior_anomaly_day (
  profile_id VARCHAR(96) NOT NULL,
  dt DATE NOT NULL,
  run_id BIGINT NOT NULL,
  source_gen_run_id BIGINT DEFAULT NULL,
  scenario_name VARCHAR(128) NOT NULL,
  traffic_pattern_score DOUBLE DEFAULT 0,
  channel_imbalance_score DOUBLE DEFAULT 0,
  session_fragmentation_score DOUBLE DEFAULT 0,
  identity_anomaly_score DOUBLE DEFAULT 0,
  conversion_distortion_score DOUBLE DEFAULT 0,
  mapping_anomaly_score DOUBLE DEFAULT 0,
  distribution_distortion_score DOUBLE DEFAULT 0,
  batch_behavior_risk_score DOUBLE DEFAULT 0,
  dominant_batch_anomaly VARCHAR(128) DEFAULT 'none',
  semantic_candidate VARCHAR(128) DEFAULT 'None',
  interpretation_status VARCHAR(64) DEFAULT 'PASS',
  interpretation_reason VARCHAR(1024) DEFAULT NULL,
  batch_anomaly_score DOUBLE DEFAULT 0,
  anomaly_status VARCHAR(64) DEFAULT 'PASS',
  anomaly_reason VARCHAR(1024) DEFAULT NULL,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (profile_id,dt,run_id,scenario_name)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
