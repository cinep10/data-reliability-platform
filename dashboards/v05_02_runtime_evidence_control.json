          "rawQuery": true,
          "rawSql": "SELECT UNIX_TIMESTAMP(r.target_date) time_sec,r.batch_evidence_score value,CONCAT(r.scenario_name,' batch') metric FROM v05_runtime_evidence_day r WHERE r.profile_id='${profile_id}' AND $__timeFilter(r.target_date) AND ('${scenario_name}'='.*' OR r.scenario_name REGEXP '${scenario_name}') UNION ALL SELECT UNIX_TIMESTAMP(r.target_date),r.stream_evidence_score,CONCAT(r.scenario_name,' stream') FROM v05_runtime_evidence_day r WHERE r.profile_id='${profile_id}' AND $__timeFilter(r.target_date) AND ('${scenario_name}'='.*' OR r.scenario_name REGEXP '${scenario_name}') UNION ALL SELECT UNIX_TIMESTAMP(r.target_date),r.operational_evidence_score,CONCAT(r.scenario_name,' operational') FROM v05_runtime_evidence_day r WHERE r.profile_id='${profile_id}' AND $__timeFilter(r.target_date) AND ('${scenario_name}'='.*' OR r.scenario_name REGEXP '${scenario_name}') UNION ALL SELECT UNIX_TIMESTAMP(r.target_date),r.realism_evidence_score,CONCAT(r.scenario_name,' realism') FROM v05_runtime_evidence_day r WHERE r.profile_id='${profile_id}' AND $__timeFilter(r.target_date) AND ('${scenario_name}'='.*' OR r.scenario_name REGEXP '${scenario_name}') ORDER BY 1",
