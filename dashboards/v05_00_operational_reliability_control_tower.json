    {
      "type": "table",
      "title": "Latest Scenario State",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT u.target_date,u.scenario_name,u.run_id,u.source_gen_run_id,u.final_risk_level,ROUND(u.overall_risk_score,6) overall_risk_score,s.dominant_semantic_risk,a.recommended_action,ROUND(COALESCE(ra.runtime_evidence_score,0),6) runtime_evidence_score,ra.dominant_runtime_signal FROM unified_reliability_score_day_v05 u LEFT JOIN semantic_interpretation_day_v05 s ON s.profile_id=u.profile_id AND s.target_date=u.target_date AND s.scenario_name=u.scenario_name AND s.run_id=u.run_id LEFT JOIN action_recommendation_day_v05 a ON a.profile_id=u.profile_id AND a.target_date=u.target_date AND a.scenario_name=u.scenario_name AND a.run_id=u.run_id AND a.action_rank=1 LEFT JOIN reliability_analysis_result_day_v05 ra ON ra.profile_id=u.profile_id AND ra.target_date=u.target_date AND ra.scenario_name=u.scenario_name AND ra.run_id=u.run_id WHERE u.profile_id='${profile_id}' AND $__timeFilter(u.target_date) AND ('${scenario_name}'='.*' OR u.scenario_name REGEXP '${scenario_name}') ORDER BY u.target_date DESC,u.run_id DESC LIMIT 100",
          "refId": "A"
        }
