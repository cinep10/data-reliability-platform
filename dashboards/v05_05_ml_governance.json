        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT UNIX_TIMESTAMP(p.target_date) time_sec,p.predicted_risk_score value FROM v05_ml_prediction_day p WHERE p.profile_id='${profile_id}' AND $__timeFilter(p.target_date) AND ('${scenario_name}'='.*' OR p.scenario_name REGEXP '${scenario_name}') ORDER BY p.target_date DESC,p.run_id DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.3
              },
              {
                "color": "red",
                "value": 0.6
              }
            ]
          }
        },
        "overrides": []
      },
