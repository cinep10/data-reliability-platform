    {
      "type": "timeseries",
      "title": "Predicted vs Actual Risk",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT UNIX_TIMESTAMP(p.target_date) time_sec,p.predicted_risk_score value,CONCAT(p.scenario_name,' predicted') metric FROM v05_ml_prediction_day p WHERE p.profile_id='${profile_id}' AND $__timeFilter(p.target_date) AND ('${scenario_name}'='.*' OR p.scenario_name REGEXP '${scenario_name}') UNION ALL SELECT UNIX_TIMESTAMP(u.target_date),u.overall_risk_score,CONCAT(u.scenario_name,' actual') FROM unified_reliability_score_day_v05 u WHERE u.profile_id='${profile_id}' AND $__timeFilter(u.target_date) AND ('${scenario_name}'='.*' OR u.scenario_name REGEXP '${scenario_name}') ORDER BY 1",
