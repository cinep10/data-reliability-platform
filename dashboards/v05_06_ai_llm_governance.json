      "type": "stat",
      "title": "AI Risk Score",
      "datasource": {
        "type": "mysql",
        "uid": "${DS_MYSQL}"
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT UNIX_TIMESTAMP(a.target_date) time_sec,a.overall_ai_risk_score value FROM v05_ai_reliability_score_day a WHERE a.profile_id='${profile_id}' AND $__timeFilter(a.target_date) AND ('${scenario_name}'='.*' OR a.scenario_name REGEXP '${scenario_name}') ORDER BY a.target_date DESC,a.run_id DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.3
              },
              {
                "color": "red",
                "value": 0.6
              }
            ]
          }
        },
        "overrides": []
      },
